# ======================================
# 生产环境 .env 模板（云服务器实操版）
# 用途：docker-compose.prod.yml 部署使用。
# 注意：复制成 .env 后，所有 REPLACE_* 都要替换成真实值。
# ======================================

# ------------------------------
# 运行与网关
# ------------------------------
# 生产环境固定 production
APP_ENV=production
# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
# 慢请求阈值（毫秒）
SLOW_REQUEST_THRESHOLD_MS=1000
# Nginx HTTP 端口
NGINX_HTTP_PORT=80
# Nginx HTTPS 端口（启用 HTTPS 时放开）
# NGINX_HTTPS_PORT=443

# ------------------------------
# 域名与鉴权
# ------------------------------
# 前端公开访问地址（必须是公网域名）
NEXTAUTH_URL=https://farm.example.com
# 浏览器看到的后端公开地址（WS URL 生成依赖）
BACKEND_PUBLIC_BASE_URL=https://farm.example.com
# 前端容器内部访问 backend 的地址（通常不用改）
BACKEND_INTERNAL_BASE_URL=http://backend:8000
# NextAuth 签名密钥（务必替换为随机长字符串）
NEXTAUTH_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET
# 后端 API 统一令牌（前端代理和 WS 都会使用）
BACKEND_API_TOKEN=REPLACE_WITH_A_LONG_RANDOM_TOKEN
# 管理员同步接口令牌（可选）
BACKEND_ADMIN_TOKEN=REPLACE_IF_YOU_USE_MANUAL_SYNC_APIS

# ------------------------------
# 外部依赖（生产必填）
# ------------------------------
# 云数据库连接（PostgreSQL / Timescale）
DATABASE_URL=postgresql://db_user:db_password@db-host:5432/hoogen_agridb?schema=public
# 云 Redis 连接
REDIS_URL=redis://redis-host:6379/0

# ------------------------------
# 对象存储（生产必填）
# ------------------------------
# 生产必须 object，不要改成 local
FILE_STORAGE_BACKEND=object
# 对象存储协议（S3 兼容）
OBJECT_STORAGE_PROVIDER=s3
# 对象存储 endpoint
OBJECT_STORAGE_ENDPOINT=https://s3.ap-east-1.amazonaws.com
# 对象存储 region
OBJECT_STORAGE_REGION=ap-east-1
# bucket 名称
OBJECT_STORAGE_BUCKET=intellifarm-prod
# Access Key ID
OBJECT_STORAGE_ACCESS_KEY_ID=REPLACE_OBJECT_STORAGE_ACCESS_KEY_ID
# Secret Access Key
OBJECT_STORAGE_SECRET_ACCESS_KEY=REPLACE_OBJECT_STORAGE_SECRET_ACCESS_KEY
# 公网访问前缀（CDN 或直连域名）
OBJECT_STORAGE_PUBLIC_BASE_URL=https://cdn.example.com
# 对象 key 前缀
OBJECT_STORAGE_PREFIX=vision/
# 路径风格（大部分 S3 兼容服务推荐 true）
OBJECT_STORAGE_FORCE_PATH_STYLE=true

# local 模式目录（生产 object 下仅保留占位）
LOCAL_STORAGE_ROOT=backend/storage

# ------------------------------
# DeepSeek（可选但建议）
# ------------------------------
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_SECONDS=20
LOCAL_LLM_ENABLED=false
LOCAL_LLM_BASE_URL=http://127.0.0.1:11434/v1
LOCAL_LLM_MODEL=qwen2.5:14b
LOCAL_LLM_TIMEOUT_SECONDS=25
COPILOT_RECOMMENDATION_MAX_ITEMS=5

# ------------------------------
# Hoogendoorn（生产建议 partner_api）
# ------------------------------
HOOGENDOORN_PROVIDER=partner_api
HOOGENDOORN_SYSTEM_ID=REPLACE_WITH_SYSTEM_ID
HOOGENDOORN_METRIC_CATALOG_PATH=backend/data/hoogendoorn_metric_catalog.private.json
HOOGENDOORN_TOKEN_URL=https://centralauthentication.hoogendoorn-iivo.cn/connect/token
HOOGENDOORN_API_BASE_URL=https://partnerapi.hoogendoorn-iivo.cn
HOOGENDOORN_CLIENT_ID=REPLACE_HOOGENDOORN_CLIENT_ID
HOOGENDOORN_CLIENT_SECRET=REPLACE_HOOGENDOORN_CLIENT_SECRET
HOOGENDOORN_SCOPE=external.partner.api
# 若你走 OAuth，可留空；若平台下发固定 token 可填
HOOGENDOORN_API_TOKEN=
HOOGENDOORN_TIMEOUT_SECONDS=15
HOOGENDOORN_RETRY_ATTEMPTS=4
HOOGENDOORN_RETRY_MIN_SECONDS=1
HOOGENDOORN_RETRY_MAX_SECONDS=8
HOOGENDOORN_SYNC_WINDOW_MINUTES=15
HOOGENDOORN_SYNC_OVERLAP_MINUTES=5

# ------------------------------
# 视觉识别运行参数
# ------------------------------
VISION_INFERENCE_MODE=onnx
VISION_MODEL_PATH=backend/models/yolov9/exp2/weights/best.onnx
VISION_QUEUE_KEY=vision:tasks
VISION_MAX_UPLOAD_MB=10
VISION_PROCESSING_TIMEOUT_MINUTES=30
VISION_CONFIDENCE_THRESHOLD=0.25

# ------------------------------
# 知识库采集
# ------------------------------
KB_HARVEST_ENABLED=true
KB_HARVEST_TIMEOUT_SECONDS=20
KB_SOURCE_FAO_BASE_URL=
KB_SOURCE_FAO_API_KEY=
KB_SOURCE_EPA_BASE_URL=
KB_SOURCE_EPA_API_KEY=

# ------------------------------
# 初始账号密码覆盖（可选）
# ------------------------------
SEED_SUPER_ADMIN_PASSWORD=
SEED_ADMIN_PASSWORD=
SEED_EXPERT_PASSWORD=
SEED_WORKER_PASSWORD=

# ------------------------------
# 兼容旧变量（生产建议留空）
# ------------------------------
API_BASE_URL=
NEXT_PUBLIC_API_BASE_URL=

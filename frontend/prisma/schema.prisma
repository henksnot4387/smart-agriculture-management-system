generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  EXPERT
  WORKER
}

enum TaskStatus {
  PENDING
  APPROVED
  IN_PROGRESS
  COMPLETED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum TaskSource {
  AI
  MANUAL
  EXTERNAL
}

enum DetectionStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

enum DetectionSource {
  CAMERA
  DRONE
  MOBILE
}

model User {
  id            String      @id @default(uuid()) @db.Uuid
  name          String?
  email         String      @unique
  emailVerified DateTime?   @map("email_verified")
  image         String?
  passwordHash  String?     @map("password_hash")
  role          UserRole    @default(WORKER)
  isActive      Boolean     @default(true) @map("is_active")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  accounts      Account[]
  sessions      Session[]
  createdTasks  Task[]      @relation("TaskCreatedBy")
  assignedTasks Task[]      @relation("TaskAssignee")
  approvedTasks Task[]      @relation("TaskApprovedBy")
  detections    Detection[] @relation("DetectionUploadedBy")

  @@index([role, isActive])
  @@map("users")
}

model Account {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  type              String
  provider          String
  providerAccountId String   @map("provider_account_id")
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Task {
  id          String       @id @default(uuid()) @db.Uuid
  title       String
  description String?      @db.Text
  status      TaskStatus   @default(PENDING)
  priority    TaskPriority @default(MEDIUM)
  source      TaskSource   @default(AI)
  metadata    Json?
  createdById String       @map("created_by_id") @db.Uuid
  assigneeId  String?      @map("assignee_id") @db.Uuid
  approvedById String?     @map("approved_by_id") @db.Uuid
  detectionId String?      @unique @map("detection_id") @db.Uuid
  approvedAt  DateTime?    @map("approved_at")
  startedAt   DateTime?    @map("started_at")
  completedAt DateTime?    @map("completed_at")
  dueAt       DateTime?    @map("due_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  createdBy   User         @relation("TaskCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  assignee    User?        @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  approvedBy  User?        @relation("TaskApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  detection   Detection?   @relation("TaskDetection", fields: [detectionId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([assigneeId, status])
  @@index([createdById])
  @@index([approvedById])
  @@map("tasks")
}

model Detection {
  id           String          @id @default(uuid()) @db.Uuid
  status       DetectionStatus @default(PROCESSING)
  source       DetectionSource
  imageUrl     String          @map("image_url")
  diseaseType  String?         @map("disease_type")
  confidence   Float?
  bbox         Json?
  rawResult    Json?           @map("raw_result")
  capturedAt   DateTime?       @map("captured_at")
  processedAt  DateTime?       @map("processed_at")
  uploadedById String?         @map("uploaded_by_id") @db.Uuid
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  uploadedBy   User?           @relation("DetectionUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)
  task         Task?           @relation("TaskDetection")

  @@index([status, createdAt])
  @@index([uploadedById, createdAt])
  @@map("detections")
}

model SensorData {
  recordedAt    DateTime @map("recorded_at") @db.Timestamptz(6)
  id            String   @default(uuid()) @db.Uuid
  greenhouseZone String  @map("greenhouse_zone")
  deviceId      String   @map("device_id")
  temperature   Float?
  humidity      Float?
  ec            Float?
  ph            Float?
  extras        Json?
  createdAt     DateTime @default(now()) @map("created_at")

  @@id([recordedAt, id])
  @@index([recordedAt])
  @@index([greenhouseZone, recordedAt])
  @@index([deviceId, recordedAt])
  @@index([id])
  @@map("sensor_data")
}

# ======================================
# frontend 环境变量模板（中文注释版）
# 用法：复制为 frontend/.env.local 后修改。
# ======================================

# NextAuth 会话签名密钥（务必修改）
NEXTAUTH_SECRET="A_VERY_LONG_RANDOM_STRING_HERE"
# 前端访问地址
NEXTAUTH_URL="http://127.0.0.1:3000"

# 生产部署 双地址：
# 1) INTERNAL：Next.js route handler 在服务端访问 backend
BACKEND_INTERNAL_BASE_URL="http://127.0.0.1:8000"
# 2) PUBLIC：返回给浏览器使用（例如 WS URL）
BACKEND_PUBLIC_BASE_URL="http://127.0.0.1:8000"

# 兼容旧代理逻辑（建议保留）
API_BASE_URL="http://127.0.0.1:8000"
NEXT_PUBLIC_API_BASE_URL="http://127.0.0.1:8000"

# 后端受保护 API 统一令牌
BACKEND_API_TOKEN="replace-with-long-random-token"

# 前端 Prisma 连接数据库（用于登录校验等）
DATABASE_URL="postgresql://admin:change-me-in-local-env@localhost:5432/hoogen_agridb?schema=public"

# 开发账号种子密码（可选覆盖）
SEED_SUPER_ADMIN_PASSWORD="change-me-superadmin-password"
SEED_EXPERT_PASSWORD="change-me-expert-password"
SEED_WORKER_PASSWORD="change-me-worker-password"

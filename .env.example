# ======================================
# 根目录环境变量模板（中文注释版）
# 用途：本地开发与脚本统一读取（restart_dev / verify / compose）。
# 用法：复制为 .env 后再改成你的真实值。
# ======================================

# ------------------------------
# 基础端口配置（冲突时可改）
# ------------------------------
# PostgreSQL 映射端口
PG_PORT=5432
# Redis 映射端口
REDIS_PORT=6379
# 前端 Next.js 端口
FRONTEND_PORT=3000
# 后端 FastAPI 端口
BACKEND_PORT=8000
# Nginx 网关端口（生产/类生产）
NGINX_HTTP_PORT=80
# 应用运行环境：development / production
APP_ENV=development

# ------------------------------
# PostgreSQL / TimescaleDB
# ------------------------------
# 数据库用户名
POSTGRES_USER=admin
# 数据库密码
POSTGRES_PASSWORD=change-me-local-db-password
# 数据库名称
POSTGRES_DB=hoogen_agridb

# ------------------------------
# 数据连接（前后端共用）
# ------------------------------
# Prisma + backend 的数据库连接串
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${PG_PORT}/${POSTGRES_DB}?schema=public"
# Redis 连接串
REDIS_URL="redis://localhost:${REDIS_PORT}/0"

# ------------------------------
# 前端代理 -> 后端地址（生产部署 双地址）
# ------------------------------
# Next.js 服务端代理在容器内访问后端的地址
BACKEND_INTERNAL_BASE_URL="http://127.0.0.1:${BACKEND_PORT}"
# 浏览器访问/WS 返回使用的公开地址
BACKEND_PUBLIC_BASE_URL="http://127.0.0.1:${BACKEND_PORT}"
# 兼容旧逻辑的回退地址（后续会逐步移除）
API_BASE_URL="http://127.0.0.1:${BACKEND_PORT}"

# ------------------------------
# 外部能力（AI / Hoogendoorn）
# ------------------------------
# DeepSeek Key
DEEPSEEK_API_KEY="REPLACE_WITH_DEEPSEEK_API_KEY"
# DeepSeek 接口地址
DEEPSEEK_BASE_URL="https://api.deepseek.com"
# DeepSeek 模型名
DEEPSEEK_MODEL="deepseek-chat"
# DeepSeek 请求超时（秒）
DEEPSEEK_TIMEOUT_SECONDS=20
# 本地 LLM 兜底（可选，建议接入 Ollama/OpenAI 兼容服务）
LOCAL_LLM_ENABLED=false
LOCAL_LLM_BASE_URL="http://127.0.0.1:11434/v1"
LOCAL_LLM_MODEL="qwen2.5:14b"
LOCAL_LLM_TIMEOUT_SECONDS=25
# AI 智能解析单次建议最多生成条数
COPILOT_RECOMMENDATION_MAX_ITEMS=5

# Hoogendoorn provider：mock / partner_api
HOOGENDOORN_PROVIDER="mock"
# Hoogendoorn 系统 ID（开源模板不提供真实值）
HOOGENDOORN_SYSTEM_ID="REPLACE_WITH_SYSTEM_ID"
# 可选：私有参数目录路径。建议把真实映射放到忽略文件中，例如：
# HOOGENDOORN_METRIC_CATALOG_PATH="backend/data/hoogendoorn_metric_catalog.private.json"
# OAuth token 地址
HOOGENDOORN_TOKEN_URL="https://centralauthentication.hoogendoorn-iivo.cn/connect/token"
# Partner API 根地址
HOOGENDOORN_API_BASE_URL="https://partnerapi.hoogendoorn-iivo.cn"
# OAuth 客户端 ID
HOOGENDOORN_CLIENT_ID=""
# OAuth 客户端密钥
HOOGENDOORN_CLIENT_SECRET=""
# OAuth scope
HOOGENDOORN_SCOPE="external.partner.api"
# 直接 token 模式（可选）
HOOGENDOORN_API_TOKEN=""
# 同步失败重试次数
HOOGENDOORN_RETRY_ATTEMPTS=4
# 重试最小间隔（秒）
HOOGENDOORN_RETRY_MIN_SECONDS=1
# 重试最大间隔（秒）
HOOGENDOORN_RETRY_MAX_SECONDS=8
# 单次同步窗口（分钟）
HOOGENDOORN_SYNC_WINDOW_MINUTES=15
# 断线补录重叠窗口（分钟）
HOOGENDOORN_SYNC_OVERLAP_MINUTES=5
# mock 分区数量
HOOGENDOORN_MOCK_ZONE_COUNT=4
# mock 采样间隔（分钟）
HOOGENDOORN_MOCK_INTERVAL_MINUTES=5
# mock 连续失败次数（用于演练）
HOOGENDOORN_MOCK_FAILURES_BEFORE_SUCCESS=0

# 后端管理员接口令牌（/integrations/hoogendoorn/sync 等）
BACKEND_ADMIN_TOKEN=""
# 受保护后端接口统一令牌（必填）
BACKEND_API_TOKEN="replace-with-long-random-token"
# 慢请求阈值（毫秒）
SLOW_REQUEST_THRESHOLD_MS=1000

# ------------------------------
# 知识库采集（摘要收口与调度中心）
# ------------------------------
# 是否开启知识采集
KB_HARVEST_ENABLED=true
# 采集请求超时（秒）
KB_HARVEST_TIMEOUT_SECONDS=20
# 采集源占位（API Key 模式）
KB_SOURCE_FAO_BASE_URL=""
KB_SOURCE_FAO_API_KEY=""
KB_SOURCE_EPA_BASE_URL=""
KB_SOURCE_EPA_API_KEY=""

# ------------------------------
# 视觉识别（视觉推理/异步识别队列）
# ------------------------------
# 推理模式：auto / yolo / onnx / mock
VISION_INFERENCE_MODE="onnx"
# 模型路径（可填 .pt 或 .onnx，例如 /Volumes/.../exp2/weights/best.onnx）
VISION_MODEL_PATH="backend/models/yolov9/exp2/weights/best.onnx"
# Redis 队列 key
VISION_QUEUE_KEY="vision:tasks"
# 上传大小上限（MB）
VISION_MAX_UPLOAD_MB=10
# 任务处理超时（分钟）
VISION_PROCESSING_TIMEOUT_MINUTES=30
# 检测置信度阈值
VISION_CONFIDENCE_THRESHOLD=0.25
# ONNX 后处理 NMS IoU 阈值
VISION_NMS_IOU_THRESHOLD=0.45
# 可选：类别名列表（逗号分隔，不填则尝试读取模型 metadata）
VISION_CLASS_NAMES=""

# 文件存储后端：留空=按 APP_ENV 自动选择（dev=local，prod=object）
FILE_STORAGE_BACKEND=""
# 本地存储根目录（local 模式）
LOCAL_STORAGE_ROOT="backend/storage"
# 对象存储提供方（S3 兼容）
OBJECT_STORAGE_PROVIDER="s3"
# 对象存储 endpoint
OBJECT_STORAGE_ENDPOINT=""
# 对象存储 region
OBJECT_STORAGE_REGION=""
# 对象存储 bucket
OBJECT_STORAGE_BUCKET=""
# 对象存储 AK
OBJECT_STORAGE_ACCESS_KEY_ID=""
# 对象存储 SK
OBJECT_STORAGE_SECRET_ACCESS_KEY=""
# 对象存储公网访问前缀
OBJECT_STORAGE_PUBLIC_BASE_URL=""
# 对象 key 前缀
OBJECT_STORAGE_PREFIX="vision/"
# S3 path style（true/false）
OBJECT_STORAGE_FORCE_PATH_STYLE=true

# ------------------------------
# NextAuth（前端登录）
# ------------------------------
# 会话签名密钥（请改成超长随机值）
NEXTAUTH_SECRET="A_VERY_LONG_RANDOM_STRING_HERE"
# 前端访问 URL
NEXTAUTH_URL="http://127.0.0.1:${FRONTEND_PORT}"

# ------------------------------
# 开发账号种子密码
# ------------------------------
SEED_SUPER_ADMIN_PASSWORD="change-me-superadmin-password"
SEED_EXPERT_PASSWORD="change-me-expert-password"
SEED_WORKER_PASSWORD="change-me-worker-password"
